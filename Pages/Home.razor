@page "/"
@inject IJSRuntime JSRuntime
@using TSFamilyFun.UIComponents
@using TSFamilyFun.Models

<PageTitle>TSFamilyFun - Stavanger Plaza</PageTitle>

<div class="app-viewport">
    <canvas id="renderCanvas"></canvas>
    
    <div class="ui-layer">
        @if (!string.IsNullOrEmpty(CurrentUserName))
        {
            <div class="top-hud glass-panel">
                <span class="hud-name">@CurrentUserName</span>
                <span class="hud-status">Online</span>
                <button class="build-toggle @(IsRecreationMode ? "recreation-active" : "")" @onclick="ToggleRecreationMode">
                    @(IsRecreationMode ? "🛹 Exit Recreation" : "🛹 Recreation")
                </button>
                <button class="build-toggle @(IsPetsMode ? "pets-active" : "")" @onclick="TogglePetsMode">
                    @(IsPetsMode ? "🐶 Exit Pets" : "🐶 Pets")
                </button>
                <button class="build-toggle @(IsBuildMode ? "active" : "")" @onclick="ToggleBuildMode">
                    @(IsBuildMode ? "🔨 Exit Build" : "🔨 Build")
                </button>
            </div>

            @if (IsBuildMode)
            {
                <div class="build-menu glass-panel">
                    <span class="menu-title">Blueprints</span>
                    <div class="asset-list">
                        <div class="asset-item @(SelectedAsset == "apple_tree" ? "selected" : "")" @onclick="@(() => SelectAsset("apple_tree"))">🍎 Apple Tree</div>
                        <div class="asset-item @(SelectedAsset == "park_bench" ? "selected" : "")" @onclick="@(() => SelectAsset("park_bench"))">🛋️ Park Bench</div>
                        <div class="asset-item @(SelectedAsset == "red_house" ? "selected" : "")" @onclick="@(() => SelectAsset("red_house"))">🏠 Red House</div>
                        <div class="asset-item @(SelectedAsset == "stavanger_pub" ? "selected" : "")" @onclick="@(() => SelectAsset("stavanger_pub"))">🍻 Stavanger Pub</div>
                        <div class="asset-item @(SelectedAsset == "stavanger_burger" ? "selected" : "")" @onclick="@(() => SelectAsset("stavanger_burger"))">🍔 Stavanger Burger</div>
                        <div class="asset-item @(SelectedAsset == "stavanger_pizza" ? "selected" : "")" @onclick="@(() => SelectAsset("stavanger_pizza"))">🍕 Stavanger Pizza</div>
                        <div class="asset-item @(SelectedAsset == "street_light" ? "selected" : "")" @onclick="@(() => SelectAsset("street_light"))">🏮 Street Light</div>
                    </div>
                    <div class="build-tools">
                        <button class="bulldozer-btn @(IsBulldozerMode ? "active" : "")" @onclick="ToggleBulldozer">🚜 Bulldozer</button>
                    </div>
                </div>
            }
            
            @if (IsRecreationMode)
            {
                <div class="build-menu glass-panel">
                    <span class="menu-title">Recreation</span>
                    <div class="asset-list">
                        <div class="asset-item @(TransportMode == "walk" ? "selected" : "")" @onclick="@(() => SetTransport("walk"))">🚶 Walking</div>
                        <div class="asset-item @(TransportMode == "skate" ? "selected" : "")" @onclick="@(() => SetTransport("skate"))">🛹 Skateboard</div>
                        <div class="asset-item @(TransportMode == "scooter" ? "selected" : "")" @onclick="@(() => SetTransport("scooter"))">🛴 Scooter</div>
                        <div class="asset-item @(TransportMode == "bike" ? "selected" : "")" @onclick="@(() => SetTransport("bike"))">🚲 Bicycle</div>
                        <div class="asset-item @(TransportMode == "rc_car" ? "selected" : "")" @onclick="@(() => SetTransport("rc_car"))">🏎️ RC Car</div>
                        <div class="asset-item @(TransportMode == "rc_drone" ? "selected" : "")" @onclick="@(() => SetTransport("rc_drone"))">🚁 RC Drone</div>
                    </div>
                </div>
            }

            @if (IsPetsMode)
            {
                <div class="build-menu glass-panel">
                    <span class="menu-title">Pets</span>
                    <div class="asset-list">
                        <div class="asset-item @(SelectedAsset == "dog" ? "selected" : "")" @onclick="@(() => SelectAsset("dog"))">🐶 Dog</div>
                        <div class="asset-item @(SelectedAsset == "cat" ? "selected" : "")" @onclick="@(() => SelectAsset("cat"))">🐱 Cat</div>
                    </div>
                    <div class="build-tools">
                        <button class="bulldozer-btn @(IsBulldozerMode ? "active" : "")" @onclick="ToggleBulldozer">🚜 Remove Pet</button>
                    </div>
                </div>
            }

            <ChatOverlay Messages="ChatMessages" OnSendMessage="SendMessage" />
        }
    </div>

    <JoinScreen IsVisible="@(!HasJoined)" OnJoin="HandleJoin" />
</div>

@code {
    private bool HasJoined = false;
    private string CurrentUserName = "";
    private List<ChatMessage> ChatMessages = new();
    private bool IsBuildMode = false;
    private bool IsRecreationMode = false;
    private bool IsPetsMode = false;
    private string TransportMode = "walk";
    private bool IsBulldozerMode = false;
    private string SelectedAsset = "apple_tree";
    private DotNetObjectReference<Home>? objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("tsFamilyEngine.init", "renderCanvas");
            objRef = DotNetObjectReference.Create(this);
        }
    }

    private async Task HandleJoin(string name)
    {
        if (!string.IsNullOrWhiteSpace(name))
        {
            CurrentUserName = name;
            HasJoined = true;
            await JSRuntime.InvokeVoidAsync("tsFamilyEngine.spawnUser", name);
            
            // Listen for real Firebase chat messages
            await JSRuntime.InvokeVoidAsync("tsFamilyEngine.initChat", objRef);
        }
    }

    [JSInvokable]
    public void ReceiveChatMessage(string user, string message)
    {
        ChatMessages.Add(new ChatMessage { User = user, Message = message });
        StateHasChanged();
    }

    private async Task SendMessage(string message)
    {
        await JSRuntime.InvokeVoidAsync("tsFamilyEngine.sendChat", message);
    }

    private async Task ToggleBuildMode()
    {
        IsBuildMode = !IsBuildMode;
        if (IsBuildMode) 
        {
            IsRecreationMode = false;
            IsPetsMode = false;
        }
        await JSRuntime.InvokeVoidAsync("tsFamilyEngine.toggleBuildMode", IsBuildMode, SelectedAsset);
        if (IsBuildMode) await JSRuntime.InvokeVoidAsync("tsFamilyEngine.toggleBulldozer", false);
    }

    private async Task ToggleRecreationMode()
    {
        IsRecreationMode = !IsRecreationMode;
        if (IsRecreationMode) 
        {
            IsBuildMode = false;
            IsPetsMode = false;
            await JSRuntime.InvokeVoidAsync("tsFamilyEngine.toggleBuildMode", false);
        }
        else
        {
            // If exiting recreation while in RC mode, reset to walk
            if (TransportMode == "rc_car" || TransportMode == "rc_drone")
            {
                await SetTransport("walk");
            }
        }
    }

    private async Task TogglePetsMode()
    {
        IsPetsMode = !IsPetsMode;
        if (IsPetsMode)
        {
            IsBuildMode = false;
            IsRecreationMode = false;
            SelectedAsset = "dog"; // Default pet
            await JSRuntime.InvokeVoidAsync("tsFamilyEngine.toggleBuildMode", true, SelectedAsset);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("tsFamilyEngine.toggleBuildMode", false);
        }
    }

    private async Task SetTransport(string mode)
    {
        TransportMode = mode;
        await JSRuntime.InvokeVoidAsync("tsFamilyEngine.setTransportMode", mode);
    }

    private async Task SelectAsset(string assetId)
    {
        SelectedAsset = assetId;
        IsBulldozerMode = false;
        bool engineBuildMode = IsBuildMode || IsPetsMode;
        await JSRuntime.InvokeVoidAsync("tsFamilyEngine.toggleBuildMode", engineBuildMode, SelectedAsset);
        await JSRuntime.InvokeVoidAsync("tsFamilyEngine.toggleBulldozer", false);
    }

    private async Task ToggleBulldozer()
    {
        IsBulldozerMode = !IsBulldozerMode;
        if (IsBulldozerMode) IsBuildMode = true; 
        await JSRuntime.InvokeVoidAsync("tsFamilyEngine.toggleBulldozer", IsBulldozerMode);
        if (IsBulldozerMode) await JSRuntime.InvokeVoidAsync("tsFamilyEngine.toggleBuildMode", false);
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }
}

<style>
    .top-hud {
        position: absolute;
        top: 20px;
        left: 20px;
        padding: 0.5rem 1.5rem;
        display: flex;
        gap: 1rem;
        align-items: center;
        color: var(--white);
    }

    .hud-name {
        font-weight: 700;
    }

    .hud-status {
        font-size: 0.8rem;
        color: #4caf50;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .build-toggle {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 700;
        transition: all 0.2s;
        margin-left: 1rem;
    }

    .build-toggle:hover {
        background: rgba(255, 255, 255, 0.2);
    }

    .build-toggle.active {
        background: #f44336;
        border-color: #f44336;
    }

    .build-toggle.recreation-active {
        background: #2196f3;
        border-color: #2196f3;
    }

    .build-toggle.pets-active {
        background: #ff9800;
        border-color: #ff9800;
    }

    .build-menu {
        position: absolute;
        top: 80px;
        right: 20px;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        width: 200px;
    }

    .menu-title {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: rgba(255, 255, 255, 0.5);
    }

    .asset-list {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        max-height: 150px;
        overflow-y: auto;
    }

    .build-tools {
        margin-top: 1rem;
        padding-top: 0.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .bulldozer-btn {
        width: 100%;
        padding: 0.6rem;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 8px;
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-weight: 700;
        transition: all 0.2s;
    }

    .bulldozer-btn.active {
        background: #f44336;
        border-color: white;
        box-shadow: 0 0 15px rgba(244, 67, 54, 0.4);
    }

    .bulldozer-btn:hover {
        background: rgba(255, 255, 255, 0.2);
    }

    .asset-item {
        padding: 0.6rem 1rem;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid transparent;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s;
        color: white;
    }

    .asset-item:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    .asset-item.selected {
        background: rgba(76, 175, 80, 0.2);
        border-color: #4caf50;
    }
</style>
