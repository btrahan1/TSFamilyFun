@using TSFamilyFun.Models
@inject IJSRuntime JSRuntime

<div class="chat-container glass-panel">
    <div class="chat-history" @ref="chatHistory">
        @foreach (var msg in Messages)
        {
            <div class="chat-entry">
                <span class="chat-user">@msg.User:</span>
                <span class="chat-text">@msg.Message</span>
            </div>
        }
    </div>
    <div class="chat-input-area">
        <input type="text" @bind="CurrentMessage" @bind:event="oninput" @onkeyup="HandleKeyUp" placeholder="Chat..." class="chat-input" />
        <button class="chat-send-btn" @onclick="SendMessage">↵</button>
    </div>
</div>

@code {
    [Parameter] public List<ChatMessage> Messages { get; set; } = new();
    [Parameter] public EventCallback<string> OnSendMessage { get; set; }
    
    private string CurrentMessage { get; set; } = "";
    private ElementReference chatHistory;
    private int messageCount = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Messages.Count != messageCount)
        {
            messageCount = Messages.Count;
            await JSRuntime.InvokeVoidAsync("tsFamilyEngine.scrollToBottom", chatHistory);
        }
    }

    private async Task SendMessage()
    {
        if (!string.IsNullOrWhiteSpace(CurrentMessage))
        {
            await OnSendMessage.InvokeAsync(CurrentMessage);
            CurrentMessage = "";
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }
}

<style>
    .chat-container {
        position: absolute;
        bottom: 80px; /* Moved up for mobile/keyboard clearance */
        left: 20px;
        width: 320px;
        max-height: 25vh; /* Quarter of the screen at most */
        display: flex;
        flex-direction: column;
        padding: 10px;
        gap: 10px;
        pointer-events: auto;
    }

    .chat-history {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding-right: 5px;
    }
    
    /* Custom Scrollbar */
    .chat-history::-webkit-scrollbar {
        width: 6px;
    }

    .chat-history::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.3);
        border-radius: 3px;
    }

    .chat-entry {
        font-size: 0.9rem;
        line-height: 1.2;
        color: var(--white);
        word-break: break-word;
    }

    .chat-user {
        font-weight: 700;
        color: var(--accent-yellow);
        margin-right: 5px;
    }

    .chat-input-area {
        display: flex;
        gap: 8px;
        height: 40px;
    }

    .chat-input {
        flex: 1;
        height: 100%;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 6px;
        padding: 0 10px;
        color: var(--white);
        outline: none;
    }

    .chat-input:focus {
        border-color: var(--accent-yellow);
    }

    .chat-send-btn {
        width: 45px;
        height: 100%;
        background: var(--accent-yellow);
        border: none;
        border-radius: 6px;
        color: #333;
        font-size: 1.2rem;
        font-weight: bold;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.1s;
    }

    .chat-send-btn:active {
        transform: scale(0.95);
    }
</style>
